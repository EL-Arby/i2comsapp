<sigml>
<hamgestural_sign gloss="wathaa chay">
  <sign_nonmanual>
 <mouthing_tier>
      <mouth_picture picture="AAA"/>
    </mouthing_tier>
  </sign_nonmanual>
  <sign_manual>
    <handconfig handshape="finger2" mainbend="221" thumbpos="across"/>
