<sigml>
<hamgestural_sign gloss="judjment">
  <sign_nonmanual>
   <mouthing_tier>
      <mouth_picture picture="OOCCKB"/>
    </mouthing_tier>
 <extra_tier>
      <extra_par>
        <extra_movement movement="X65"/>
      </extra_par>
    </extra_tier>
  </sign_nonmanual>
  <sign_manual>
    <handconfig handshape="finger23"  mainbend="100"  thumbpos="across"/>
    <handconfig extfidir="ou" palmor="l"/>
