    <par_motion>
      <directedmotion direction="d"  curve="u" size="big"/>
      <tgt_motion>
    <handconfig extfidir="d" palmor="dl"/>
      </tgt_motion>
    </par_motion>
  </sign_manual>
</hamgestural_sign>
</sigml>
