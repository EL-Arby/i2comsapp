<sigml>
<hamgestural_sign gloss="$PROD">
  <sign_nonmanual>
<mouthing_tier>
      <mouth_picture picture="BLK"/>
    </mouthing_tier>
  </sign_nonmanual>
  <sign_manual>
    <handconfig handshape="flat" thumbpos="out"/>
    <handconfig extfidir="u"/>
    <handconfig palmor="d"/>
    <location_bodyarm contact="close" location="forehead"/>
    <directedmotion direction="ui" size="small"/>
   
  </sign_manual>
</hamgestural_sign>
</sigml>