<sigml>
<hamgestural_sign gloss="Third">
<sign_nonmanual>
    <mouthing_tier>
      <mouth_picture picture="THA"/>
    </mouthing_tier>
 </sign_nonmanual>

  <sign_manual>
    <handconfig handshape="finger23spread"   bend3="222"   thumbpos="out"/>
    <handconfig extfidir="l"/>
