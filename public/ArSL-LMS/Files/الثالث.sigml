    <location_bodyarm location="shoulders" contact="close" side="right_at"/>
<tgt_motion>
    <handconfig handshape="finger23spread"       thumbpos="out"/>
</tgt_motion>
  </sign_manual>
</hamgestural_sign>
</sigml>
