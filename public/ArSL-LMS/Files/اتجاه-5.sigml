<sigml>
<hamgestural_sign gloss="direction">
  <sign_manual>
    <handconfig handshape="flat"  extfidir="u"  palmor="l"/>
    <location_bodyarm location="head"  side="right_at"  contact="close" />
         <tgt_motion>
 <directedmotion direction="o"  size="big" curve="u" />
        <handconfig   handshape="flat" extfidir="o"  palmor="l"/>
<location_bodyarm location="shoulders" side="right_at"    contact="armextended"/>
      </tgt_motion>
    
  </sign_manual>
</hamgestural_sign>
</sigml>
