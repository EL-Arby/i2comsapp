<sigml>

<hamgestural_sign gloss="Silent">
  <sign_manual both_hands="true" >
    
 <split_handconfig>
      <handconfig handshape="flat"    extfidir="lu" palmor="l" thumbpos="out"/>
      <handconfig handshape="flat"   extfidir="r" palmor="r"/>
    </split_handconfig>
 
 <split_location>
	<location_bodyarm location="chin" contact="armsextende"/>
	<location_bodyarm location="chest"   contact="touch" />
    </split_location>


  </sign_manual>
</hamgestural_sign>

</sigml>