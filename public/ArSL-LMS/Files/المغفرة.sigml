<sigml>
<hamgestural_sign gloss="$PROD">
  <sign_nonmanual>
    <mouthing_tier>
      <mouth_picture picture="ghafar"/>
    </mouthing_tier>
  </sign_nonmanual>
  <sign_manual>
    <handconfig handshape="flat" thumbpos="out"/>
    <handconfig extfidir="il"/>
    <handconfig palmor="r"/>
    <location_bodyarm contact="close" location="shouldertop"/>
    <directedmotion direction="il"/>
    <wristmotion motion="nodding" manner="slow" />
  </sign_manual>
</hamgestural_sign>
</sigml>