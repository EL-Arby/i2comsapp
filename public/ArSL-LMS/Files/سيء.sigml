<sigml>
<hamgestural_sign gloss="bad">
 <sign_nonmanual>
    <mouthing_tier>
      <mouth_picture picture="BATL"/>
    </mouthing_tier>
  </sign_nonmanual>
  <sign_manual>
   
        <handconfig handshape="fist"  thumbpos="out"  extfidir="u" palmor="d"/>  
      <location_bodyarm location="shouldertop" side="right_at" contact="close"/>
<tgt_motion>
