    <par_motion>
      <directedmotion direction="r" size="small" manner="fast"  />
      <tgt_motion>
        <changeposture/>
        <handconfig extfidir="ru" palmor="ru"/>
      </tgt_motion>
    </par_motion>
  </sign_manual>
</hamgestural_sign>
</sigml>
