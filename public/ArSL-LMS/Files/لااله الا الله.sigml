    <handconfig palmor="dl"/>
    <location_bodyarm location="shoulders"/>
    <directedmotion direction="r" size="big"/>
    <directedmotion direction="l"/>
    <circularmotion axis="u"/>
    <directedmotion direction="ul" size="small"/>
    <directedmotion direction="u"/>
  </sign_manual>
</hamgestural_sign>
</sigml>