<sigml>
<hamgestural_sign gloss="la elah ela allah">
  <sign_nonmanual>
    <mouthing_tier>
      <mouth_picture picture="lamelahelallah"/>
    </mouthing_tier>
  </sign_nonmanual>
  <sign_manual>
    <handconfig handshape="finger2" thumbpos="across" />
