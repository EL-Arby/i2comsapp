<sigml>
<hamgestural_sign gloss="change">
  <sign_manual>
    <handconfig handshape="finger23spread" thumbpos="across"/>
    <handconfig extfidir="l"/>
    <handconfig palmor="r"/>
    <location_bodyarm location="cheek" side="right_beside"  contact="touch"/>
    <par_motion>
      
      <tgt_motion>
        <changeposture/>
        <handconfig extfidir="l" palmor="d"/>
      </tgt_motion>
    </par_motion>
  </sign_manual>
</hamgestural_sign>
</sigml>
