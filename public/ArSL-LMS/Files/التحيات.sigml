<sigml>
<hamgestural_sign gloss="taheyat">
  <sign_nonmanual>
    <mouthing_tier>
      <mouth_gesture movement="L04"/>
    </mouthing_tier>
  </sign_nonmanual>
  <sign_manual both_hands="true" lr_symm="true">
