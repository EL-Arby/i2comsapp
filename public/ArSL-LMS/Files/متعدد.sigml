<sigml>
<hamgestural_sign gloss="$PROD">
  <sign_nonmanual/>
  <sign_manual>
    <handconfig  handshape="finger23spread" bend3="200" thumbpos="across"/>
    <handconfig extfidir="uol"/>
    <handconfig palmor="d"/>
    <location_bodyarm contact="close" location="chest"/>
    
 <tgt_motion>
    <directedmotion direction="r" size="big"/>
    <handconfig extfidir="uo"/>
 </tgt_motion>
  </sign_manual>
</hamgestural_sign>
</sigml>