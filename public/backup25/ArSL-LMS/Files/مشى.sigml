   </tgt_motion>
 </par_motion>
   <par_motion>
    <split_motion>
<fingerplay/>
           <directedmotion />
      </split_motion>
      <tgt_motion>
<split_motion>
<directedmotion direction="lo" size="small"  curve="u"   />
           <directedmotion />
      </split_motion>
      </tgt_motion>
      <tgt_motion>
   </tgt_motion>
 </par_motion>
  </sign_manual>
</hamgestural_sign>

