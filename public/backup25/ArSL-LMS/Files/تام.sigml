<sigml>

<hamgestural_sign gloss="Okey">
<sign_nonmanual>
    <mouthing_tier>
      <mouth_picture picture="TBAB"/>
    </mouthing_tier>
 </sign_nonmanual>
  <sign_manual both_hands="true" lr_symm="true">
