<sigml>
<hamgestural_sign gloss="yarja">
  <sign_nonmanual>
    <mouthing_tier>
      <mouth_picture picture="youm"/>
    </mouthing_tier>
  </sign_nonmanual>
  <sign_manual>
    <handconfig handshape="finger2" thumbpos="across"/>
    <handconfig extfidir="l"/>
    <handconfig palmor="l"/>
    <location_bodyarm location="shoulders" side="right_at"/>
    <rpt_motion repetition="fromstart">
      <circularmotion axis="l"/>
    </rpt_motion>
  </sign_manual>
</hamgestural_sign>
</sigml>