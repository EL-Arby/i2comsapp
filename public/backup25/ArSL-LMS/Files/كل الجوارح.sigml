<sigml>

<hamgestural_sign gloss="fall">
 <sign_nonmanual>
<mouthing_tier>
      <mouth_picture picture="KOOOOO"/>
    </mouthing_tier>
 <extra_tier>
<extra_par>
      <extra_movement movement="X61"/>
</extra_par>
<extra_par>
      <extra_movement movement="X61"/>
</extra_par>
    </extra_tier>

  </sign_nonmanual>

  <sign_manual both_hands="true" lr_symm="true">
    <handconfig handshape="finger2" mainbend="200"  thumbpos="across"/>
    <handconfig extfidir="liu" palmor="d"/>
    <location_bodyarm location="headtop" side="right_at"  contact="close"  />

 <tgt_motion>
     <directedmotion direction="d"  manner="slow" size="big"/>  
  <handconfig extfidir="l" palmor="l"/>
    <location_bodyarm location="stomach"    contact="close"  />

 
 </tgt_motion>
	
 </sign_manual>
</hamgestural_sign>

</sigml>