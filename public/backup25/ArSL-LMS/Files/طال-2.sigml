<sigml>
<hamgestural_sign gloss="tall">
 <sign_manual both_hands="true" lr_symm="true" outofphase="true">
    <handconfig handshape="finger2" thumbpos="across"  extfidir="l" palmor="l"/>
    <handconstellation contact="touch">
      <location_hand location="tip" digits="2"/>
     <location_hand location="tip" digits="2"/>
      <location_bodyarm location="shoulders"/>
    </handconstellation>
    <directedmotion direction="r"  size="big"   />
   
  </sign_manual>
</hamgestural_sign>
</sigml>
