<sigml>

<hamgestural_sign gloss="athan">
<sign_nonmanual>
	 <eyegaze_tier>
      <eye_gaze direction="UP"/>
    </eyegaze_tier>
   
  </sign_nonmanual>
  <sign_manual both_hands="true" lr_symm="true">
    <handconfig handshape="finger2" thumbpos="across"/>
    <handconfig extfidir="ul" palmor="dr"/>
    <location_bodyarm location="ear" contact="touch"  />
 
  </sign_manual>
</hamgestural_sign>

</sigml>