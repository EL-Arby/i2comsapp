<sigml>


<hamgestural_sign gloss="leave">
  <sign_manual>
      <handconfig handshape="flat"   thumbpos="out"/>
      <handconfig extfidir="l" palmor="l"/>
    <location_bodyarm location="shouldertop" side="right_at" contact="close"  />
	<tgt_motion>
 <directedmotion direction="or"    size="big"    />
      <handconfig extfidir="our" palmor="l"/>
  </tgt_motion>
  </sign_manual>
</hamgestural_sign>

	
</sigml>