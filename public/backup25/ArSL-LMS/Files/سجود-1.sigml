<sigml>

<hamgestural_sign gloss="SJood">
  <sign_manual both_hands="true" >
    
 <split_handconfig>
      <handconfig handshape="flat" mainbend="100"    extfidir="u" palmor="u"/>
      <handconfig handshape="flat"   extfidir="r" palmor="r"/>
    </split_handconfig>
 
 <split_location>
	<location_bodyarm location="nose"   contact="touch"/>
	<location_bodyarm location="chest"   contact="touch" />
    </split_location>



  </sign_manual>
</hamgestural_sign>

</sigml>